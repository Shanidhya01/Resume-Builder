rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /resumes/{resumeId} {
      // Owner: full read (get + list), create, update, delete.
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;

      // Public sharing: anonymous visitors may READ a published resume by its
      // exact document id, but never list/query the collection — the only way
      // to reach one is its slug mapping in /publicSlugs. This is defense in
      // depth: the primary public read path (/r/[slug]) now runs server-side
      // through the Admin SDK. There is deliberately NO public `update` — every
      // analytics counter (view/download/share) is written by trusted server
      // code via the Admin SDK, so anonymous clients can never modify a resume.
      allow get: if resource.data.isPublic == true;

      match /versions/{versionId} {
        allow read, write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/resumes/$(resumeId)).data.ownerId;
      }

      // Unique-visitor markers. Owner reads them (via a count() query) for
      // analytics; writes are performed exclusively by the Admin SDK (server),
      // which bypasses these rules — hence no anonymous `write` rule here.
      match /visitors/{visitorId} {
        allow read: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/resumes/$(resumeId)).data.ownerId;
      }
    }

    // slug -> resumeId lookup. `get` only (never `list`), so slugs can't be
    // enumerated. Restricted to signed-in users because the only client-side
    // reader is the owner's slug-availability check during publish; anonymous
    // public resolution happens server-side via the Admin SDK. `create` requires
    // the caller to own the target resume, and Firestore's create semantics
    // (fails if the doc exists) make slug claiming first-come-first-served.
    match /publicSlugs/{slug} {
      allow get: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // Import history log. One doc per import attempt, strictly owner-scoped.
    // Entries are immutable once written (no update) — the owner can only read
    // and delete them.
    match /importHistory/{entryId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
  }
}

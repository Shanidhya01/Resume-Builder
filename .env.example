# Firebase project config.
# Get these from Firebase Console > Project Settings > General > Your apps > SDK setup and configuration.
# https://console.firebase.google.com

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Public base URL of this deployment, used to build absolute public-resume
# share links (/r/<slug>) and SEO metadata (canonical URL, Open Graph, Twitter
# Card, JSON-LD). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app




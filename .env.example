# Firebase project config.
# Get these from Firebase Console > Project Settings > General > Your apps > SDK setup and configuration.
# https://console.firebase.google.com

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Public base URL of this deployment, used to build absolute public-resume
# share links (/r/<slug>) and SEO metadata (canonical URL, Open Graph, Twitter
# Card, JSON-LD). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app


# ---------------------------------------------------------------------------
# Firebase Admin SDK (SERVER-ONLY — never prefixed NEXT_PUBLIC, never sent to
# the browser). Used for all server-side Firestore access: /r/<slug> rendering,
# metadata, and the app/api/public/* analytics routes.
#
# Get these from Firebase Console > Project Settings > Service accounts >
# "Generate new private key". The downloaded JSON contains project_id,
# client_email and private_key.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the whole PEM on ONE line with the newlines escaped as \n, wrapped in
# double quotes. On Vercel, paste the raw multi-line value (no surrounding
# quotes) into the dashboard instead.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Optional: salt for the daily one-way hash of visitor IPs used to count unique
# public-resume viewers. Defaults to a built-in constant if unset.
VISITOR_HASH_SALT=change-me-to-a-long-random-string



